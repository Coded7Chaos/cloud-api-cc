APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Notificaciones del navegador (panel web).
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_VAPID_SUBJECT="${APP_URL}"

# ---------------------------------------------------------------------------
# API para las apps móviles
# ---------------------------------------------------------------------------

# Dominios que autentican por cookie de sesión (el SPA del panel). Las apps
# móviles NO van acá: usan token Bearer. Si se deja vacío, Sanctum toma APP_URL.
SANCTUM_STATEFUL_DOMAINS=

# Minutos de vida de los tokens de las apps. Vacío = no caducan y el agente
# sigue logueado entre turnos, que es lo que se quiere por defecto.
SANCTUM_EXPIRATION=

# Orígenes web cruzados permitidos, separados por coma (p. ej. una build web
# de la app Flutter). Vacío = ninguno, que es lo correcto si solo existen el
# SPA de mismo origen y las apps nativas.
CORS_ALLOWED_ORIGINS=

# --- APNs (notificaciones nativas de iOS) ---
# Clave .p8 de Apple Developer > Certificates, Identifiers & Profiles > Keys,
# con el servicio "Apple Push Notifications" habilitado.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
# La clave, o pegada acá (con \n literales) o por ruta de archivo.
APNS_PRIVATE_KEY=
APNS_PRIVATE_KEY_PATH=
# false = sandbox, que es el entorno de las builds instaladas desde Xcode.
# TestFlight y App Store usan producción.
APNS_PRODUCTION=false

# --- FCM (notificaciones nativas de Android) ---
# Service account de Firebase > Configuración del proyecto > Cuentas de
# servicio > Generar nueva clave privada. El envío de mensajes no tiene costo.
FCM_PROJECT_ID=
# El JSON, o pegado acá o por ruta de archivo.
FCM_CREDENTIALS=
FCM_CREDENTIALS_PATH=
# Tiene que coincidir con el NotificationChannel que crea la app Android.
FCM_CHANNEL_ID=chats
